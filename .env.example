# Model provider used by tutorials.model_config.get_model().
# Common values in this assignment: gemini, groq, vertexai.
MODEL_PROVIDER=gemini

# LLM provider credentials.
# Fill only the key for the provider you are going to use.
GOOGLE_API_KEY=replace-with-your-gemini-api-key
GROQ_API_KEY=replace-with-your-groq-api-key

# Google Cloud / BigQuery.
GOOGLE_CLOUD_PROJECT=replace-with-your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
BIGQUERY_LOCATION=US
BIGQUERY_MAX_BYTES_BILLED=100000000

# Vertex AI / Google GenAI configuration, if MODEL_PROVIDER=vertexai.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_LOCATION=us-central1

# MCP reporting server.
ECOMINSIGHT_MCP_HOST=127.0.0.1
ECOMINSIGHT_MCP_PORT=9003

# Generated reporting outputs.
REPORTS_DIR=reports/generated
SNAPSHOTS_DIR=reports/snapshots
KPI_CARDS_DIR=reports/kpi_cards
